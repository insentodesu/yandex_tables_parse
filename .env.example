# MAX bot
SEND_MODE=max
MAX_BOT_TOKEN=your_max_bot_token
MAX_CHAT_ID=123456789
MAX_SSL_VERIFY=true

# Optional: override User-Agent for table HTTP fetches (default is a Chrome-like string for Yandex CDN).
# HTTP_USER_AGENT=

# Polling
POLL_INTERVAL_SECONDS=60
RETRY_ATTEMPTS=2
RETRY_DELAY_SECONDS=2

# After HTTP 429 from table fetch, extra sleep before next cycle (0 = off)
RATE_LIMIT_COOLDOWN_SECONDS=90

# HTTP retries when loading the table (Yandex 429/502/503)
TABLE_FETCH_MAX_RETRIES=6
TABLE_FETCH_RETRY_BASE_SECONDS=2
TABLE_FETCH_RETRY_MAX_SLEEP_SECONDS=120

# Storage
DATABASE_PATH=data/accounting_max_bot.db

# Table source
# Recommended production mode for a live Yandex Table:
# 1) Publish the table and copy the public Yandex link
# 2) Use yandex_public_xlsx so the bot resolves the file through Yandex API
TABLE_SOURCE_TYPE=yandex_public_xlsx
TABLE_SOURCE=https://disk.yandex.ru/i/your-public-table-link
TABLE_SHEET_NAME=
TABLE_COMMAND_COLUMN=Бухгалтеру в чат

# Optional: password-protected public link or file inside a published folder
# TABLE_YANDEX_PUBLIC_PASSWORD=
# TABLE_YANDEX_PUBLIC_PATH=

# OAuth Disk when public download is blocked (yandex_disk_xlsx / yandex_disk_csv).
# TABLE_SOURCE не обязателен в этом режиме.
# Получение токена: https://oauth.yandex.com/client/new/ → права cloud_api:disk.read →
# https://oauth.yandex.ru/authorize?response_type=token&client_id=<ClientID>
# YANDEX_DISK_TOKEN=
# TABLE_DISK_PATH=disk:/folder/file.xlsx

# One-time migration helper from the source Google Sheet
SOURCE_GOOGLE_CSV_URL=https://docs.google.com/spreadsheets/d/16gaolLjUU7yCaHrKKfZ6wRHvAgDO0Be33-YUupGFFHw/export?format=csv&gid=1401714661
TEMPLATE_OUTPUT_PATH=templates/yandex_accounting_template.xlsx
SOURCE_STRUCTURE_PATH=templates/source_sheet_structure.json
